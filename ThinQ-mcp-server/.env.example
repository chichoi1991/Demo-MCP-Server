# LG ThinQ API Credentials
# .env 파일을 생성하고 아래 값들을 설정하세요.
# 절대로 .env를 git에 커밋하지 마세요!

# PAT Token은 MCP 클라이언트가 x-thinq-pat-token 헤더로 전달
# THINQ_PAT_TOKEN=

# API Key는 고정값 (변경 불필요)
# THINQ_API_KEY=v6GFvkweNo7DK7yD3ylIZ9w52aKBU0eJ7wLXkSR3

# Base URL (선택사항)
# THINQ_BASE_URL=https://api-kic.lgthinq.com

